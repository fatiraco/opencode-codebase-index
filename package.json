{
  "name": "opencode-codebase-index",
  "version": "14.2.0",
  "description": "Plugin minimale per la ricerca semantica del codebase in OpenCode su Windows x64",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "license": "MIT",
  "author": "Fabrizio Tiracorrendo",
  "repository": {
    "type": "git",
    "url": "https://github.com/fatiraco/opencode-codebase-index.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "npm run build:ts && npm run build:native",
    "build:ts": "tsup",
    "build:native": "cd native && napi build --release --platform --target x86_64-pc-windows-msvc",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "napi": {
    "binaryName": "codebase-index-native",
    "targets": [
      "x86_64-pc-windows-msvc"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/plugin": "~1.3.13",
    "chokidar": "^5.0.0",
    "ignore": "^7.0.5",
    "p-queue": "^9.1.1",
    "p-retry": "^7.1.1",
    "tiktoken": "^1.0.15",
    "typebox": "^1.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@napi-rs/cli": "^3.6.0",
    "@types/node": "^25.5.2",
    "eslint": "^9.39.4",
    "tsup": "^8.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "brace-expansion": "5.0.6",
    "express-rate-limit": "8.5.2",
    "fast-uri": "3.1.2",
    "hono": "4.12.25",
    "ip-address": "10.2.0",
    "postcss": "8.5.15",
    "qs": "6.15.2",
    "vite": "8.0.16",
    "esbuild": "0.28.1"
  }
}
